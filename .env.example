# ============================================================
# Piano Flex LINE予約システム 環境変数設定
# このファイルをコピーして .env として保存し、各値を設定してください
# ============================================================

# --- LINE Messaging API ---
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# --- LIFF ---
LIFF_ID=your_liff_id
# LIFFアプリのURL（例: https://your-domain.com/liff）
LIFF_URL=https://your-domain.com/liff

# --- Google Calendar API ---
# GCPサービスアカウントのJSONキーファイルパス
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account-key.json
# レッスンカレンダーのID（GoogleカレンダーURL中の英数字@group.calendar.google.com）
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# --- Square 決済リンク ---
# 料金プランごとにSquare管理画面で事前に作成しておくこと
# 東京
SQUARE_TOKYO_FIRST=https://square.link/u/xxxxxxxx         # 奏法診断 12,000円
SQUARE_TOKYO_SINGLE=https://square.link/u/xxxxxxxx        # シングル 20,000円
SQUARE_TOKYO_STANDARD=https://square.link/u/xxxxxxxx      # スタンダード 38,000円
SQUARE_TOKYO_PREMIUM=https://square.link/u/xxxxxxxx       # プレミアム 110,000円

# 大阪（動画添削あり）
SQUARE_OSAKA_ADULT_FIRST_W=https://square.link/u/xxxxxxxx    # 大人+受講未 22,000円
SQUARE_OSAKA_ADULT_DONE_W=https://square.link/u/xxxxxxxx     # 大人+受講済 25,000円
SQUARE_OSAKA_STUDENT_FIRST_W=https://square.link/u/xxxxxxxx  # 学生+受講未 18,000円
SQUARE_OSAKA_STUDENT_DONE_W=https://square.link/u/xxxxxxxx   # 学生+受講済 20,000円
SQUARE_OSAKA_JUNIOR_FIRST_W=https://square.link/u/xxxxxxxx   # ジュニア+受講未 15,000円
SQUARE_OSAKA_JUNIOR_DONE_W=https://square.link/u/xxxxxxxx    # ジュニア+受講済 18,000円

# 大阪（動画添削なし）
SQUARE_OSAKA_ADULT_FIRST=https://square.link/u/xxxxxxxx      # 大人+受講未 19,000円
SQUARE_OSAKA_ADULT_DONE=https://square.link/u/xxxxxxxx       # 大人+受講済 22,000円
SQUARE_OSAKA_STUDENT_FIRST=https://square.link/u/xxxxxxxx    # 学生+受講未 15,000円
SQUARE_OSAKA_STUDENT_DONE=https://square.link/u/xxxxxxxx     # 学生+受講済 17,000円
SQUARE_OSAKA_JUNIOR_FIRST=https://square.link/u/xxxxxxxx     # ジュニア+受講未 12,000円
SQUARE_OSAKA_JUNIOR_DONE=https://square.link/u/xxxxxxxx      # ジュニア+受講済 15,000円

# 宇都宮
SQUARE_UTSUNOMIYA_INFANT=https://square.link/u/xxxxxxxx      # 幼児・低学年 2,500円/月
SQUARE_UTSUNOMIYA_JUNIOR=https://square.link/u/xxxxxxxx      # 小学生 5,000円/月
SQUARE_UTSUNOMIYA_STUDENT=https://square.link/u/xxxxxxxx     # 学生 10,000円/月
SQUARE_UTSUNOMIYA_TEACHER=https://square.link/u/xxxxxxxx     # 教員志望 2,500円/月

# --- エルメ API ---
ERUME_API_KEY=your_erume_api_key

# --- サーバー設定 ---
PORT=3000
BASE_URL=https://your-domain.com

# --- セッション ---
# 予約セッションの有効時間（分）
SESSION_TTL_MINUTES=60
